// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "icon_theme": "Catppuccin Mocha",
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": ""
      }
    }
  },
  "vim_mode": true,
  "auto_install_extensions": {
    "catppuccin-icons": true,
    "csv": true,
    "docker-compose": true,
    "dockerfile": true,
    "git-firefly": true,
    "golangci-lint": true,
    "graphql": true,
    "html": true,
    "log": true,
    "make": true,
    "mcp-server-context7": true,
    "oxc": true,
    "proto": true,
    "ruby": true,
    "scss": true,
    "sql": true,
    "terraform": true,
    "toml": true,
    "vue": true
  },
  "project_panel": {
    "auto_reveal_entries": false
  },
  "preview_tabs": {
    "enabled": false
  },
  "status_bar": {
    "experimental.show": true
  },
  "minimap": {
    "show": "never"
  },
  "cursor_shape": "block",
  "buffer_font_fallbacks": [
    "Menlo",
    "Monaco",
    "Courier New",
    "monospace"
  ],
  "buffer_font_family": "HackGen",
  "show_edit_predictions": true,
  "tab_size": 2,
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    }
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
}
